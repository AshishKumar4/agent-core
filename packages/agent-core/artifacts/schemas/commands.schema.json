{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/1/commands.schema.json",
  "title": "Agent Core command",
  "$defs": {
    "ref": { "$ref": "common.schema.json#/$defs/resourceRef" },
    "grantIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "tenantBootstrap": { "type": "object", "required": ["tenant", "ownerMembership"], "properties": { "tenant": { "type": "object" }, "ownerPrincipalId": { "type": "string" }, "ownerPrincipal": { "type": "object" }, "ownerMembership": { "type": "object" } }, "oneOf": [{ "required": ["ownerPrincipalId"] }, { "required": ["ownerPrincipal"] }], "additionalProperties": false },
    "membershipUpdate": { "type": "object", "required": ["tenantId", "principalId", "role", "status"], "properties": { "tenantId": { "type": "string" }, "principalId": { "type": "string" }, "role": { "enum": ["owner", "admin", "member"] }, "status": { "enum": ["active", "suspended", "removed"] } }, "additionalProperties": false },
    "resourceCreate": { "type": "object", "required": ["resource", "tenantId", "record"], "properties": { "resource": { "$ref": "#/$defs/ref" }, "tenantId": { "type": "string" }, "record": { "type": "object" } }, "additionalProperties": false },
    "resourceUpdate": { "type": "object", "required": ["resource", "patch"], "properties": { "resource": { "$ref": "#/$defs/ref" }, "patch": { "type": "object" } }, "additionalProperties": false },
    "resourceTransition": { "type": "object", "required": ["resource", "state"], "properties": { "resource": { "$ref": "#/$defs/ref" }, "state": { "type": "string" } }, "additionalProperties": false },
    "resourceDelete": { "type": "object", "required": ["resource"], "properties": { "resource": { "$ref": "#/$defs/ref" } }, "additionalProperties": false },
    "grantIssue": { "type": "object", "required": ["target", "authority", "validUntil"], "properties": { "target": { "$ref": "#/$defs/ref" }, "authority": { "type": "object" }, "validUntil": { "type": "string", "format": "date-time" } }, "additionalProperties": false },
    "grantDelegate": { "type": "object", "required": ["parentGrantId", "target", "authority"], "properties": { "parentGrantId": { "type": "string" }, "target": { "$ref": "#/$defs/ref" }, "authority": { "type": "object" }, "validUntil": { "type": "string", "format": "date-time" } }, "additionalProperties": false },
    "bindingCreate": { "type": "object", "required": ["bindingId", "workspaceId", "subject", "name", "grantId"], "properties": { "bindingId": { "type": "string" }, "workspaceId": { "type": "string" }, "subject": { "$ref": "#/$defs/ref" }, "name": { "type": "string" }, "grantId": { "type": "string" } }, "additionalProperties": false },
    "runStart": { "type": "object", "required": ["agentId", "grantIds", "limits", "input"], "properties": { "agentId": { "type": "string" }, "parentRunId": { "type": "string" }, "parentTurnId": { "type": "string" }, "taskId": { "type": "string" }, "subscriptionId": { "type": "string" }, "environmentId": { "type": "string" }, "grantIds": { "$ref": "#/$defs/grantIds" }, "limits": { "type": "object" }, "input": true }, "additionalProperties": false },
    "turnStart": { "type": "object", "required": ["runId", "branchId", "mode", "input"], "properties": { "runId": { "type": "string" }, "branchId": { "type": "string" }, "fromCommitId": { "type": "string" }, "checkpointRef": { "type": "string" }, "mode": { "enum": ["initial", "user", "reaction", "retry", "resume", "proposer", "aggregator", "judge"] }, "input": true }, "additionalProperties": false },
    "turnClaim": { "type": "object", "required": ["turnId", "executorId", "leaseDurationMs", "mode"], "properties": { "turnId": { "type": "string" }, "executorId": { "type": "string" }, "leaseDurationMs": { "type": "integer", "minimum": 1 }, "mode": { "enum": ["initial", "renew", "reclaim"] } }, "additionalProperties": false },
    "turnSuspend": { "type": "object", "required": ["turnId", "checkpointRef"], "properties": { "turnId": { "type": "string" }, "checkpointRef": { "type": "string" } }, "additionalProperties": false },
    "turnRetry": { "type": "object", "required": ["predecessorTurnId", "branchId", "input"], "properties": { "predecessorTurnId": { "type": "string" }, "branchId": { "type": "string" }, "input": true }, "additionalProperties": false },
    "turnResume": { "type": "object", "required": ["predecessorTurnId", "checkpointRef"], "properties": { "predecessorTurnId": { "type": "string" }, "checkpointRef": { "type": "string" } }, "additionalProperties": false },
    "turnCancel": { "type": "object", "required": ["turnId", "reason"], "properties": { "turnId": { "type": "string" }, "reason": { "type": "string" } }, "additionalProperties": false },
    "turnDeliverEvent": { "type": "object", "required": ["turnId", "eventId"], "properties": { "turnId": { "type": "string" }, "eventId": { "type": "string" }, "payloadRef": { "type": "string" } }, "additionalProperties": false },
    "runSpawn": { "type": "object", "required": ["parentRunId", "parentTurnId", "mode", "input", "grantIds", "limits"], "properties": { "parentRunId": { "type": "string" }, "parentTurnId": { "type": "string" }, "parentBranchId": { "type": "string" }, "mode": { "enum": ["child_run", "child_agent"] }, "input": true, "grantIds": { "$ref": "#/$defs/grantIds" }, "limits": { "type": "object" } }, "additionalProperties": false },
    "runBranchCreate": { "type": "object", "required": ["runId", "branchId", "fromCommitId"], "properties": { "runId": { "type": "string" }, "branchId": { "type": "string" }, "fromCommitId": { "type": "string" }, "name": { "type": "string" }, "purpose": { "type": "string" } }, "additionalProperties": false },
    "runBranchUndo": { "type": "object", "required": ["runId", "branchId", "undoCommitId", "targetCommitId", "reason"], "properties": { "runId": { "type": "string" }, "branchId": { "type": "string" }, "undoCommitId": { "type": "string" }, "targetCommitId": { "type": "string" }, "reason": { "type": "string" } }, "additionalProperties": false },
    "runCommit": { "type": "object", "required": ["runId", "branchId", "commitId", "commitKind", "parentCommitIds", "content"], "properties": { "runId": { "type": "string" }, "turnId": { "type": "string" }, "branchId": { "type": "string" }, "commitId": { "type": "string" }, "parentCommitIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }, "commitKind": { "enum": ["message", "checkpoint", "invocation", "event", "terminal", "merge", "verdict", "undo"] }, "content": true }, "additionalProperties": false },
    "environmentRotate": { "type": "object", "required": ["environmentId", "successor"], "properties": { "environmentId": { "type": "string" }, "successor": { "type": "object" }, "snapshotRef": { "type": "string" } }, "additionalProperties": false },
    "invocationPrepare": { "type": "object", "required": ["runId", "turnId", "branchId", "sequence", "bindingId", "operation", "argumentRef", "idempotencyKey"], "properties": { "runId": { "type": "string" }, "turnId": { "type": "string" }, "branchId": { "type": "string" }, "sequence": { "type": "integer", "minimum": 0 }, "bindingId": { "type": "string" }, "operation": { "type": "string" }, "argumentRef": { "type": "string" }, "idempotencyKey": { "type": "string" } }, "additionalProperties": false },
    "approvalResolve": { "type": "object", "required": ["approvalId", "decision"], "properties": { "approvalId": { "type": "string" }, "decision": { "enum": ["approved", "denied", "cancelled"] } }, "additionalProperties": false },
    "invocationReconcile": { "type": "object", "required": ["invocationId", "evidence"], "properties": { "invocationId": { "type": "string" }, "evidence": true }, "additionalProperties": false },
    "workspaceFork": { "type": "object", "required": ["sourceWorkspaceId", "sourceRevision", "destinationTenantId", "policy"], "properties": { "sourceWorkspaceId": { "type": "string" }, "sourceRevision": { "type": "integer", "minimum": 0 }, "destinationTenantId": { "type": "string" }, "policy": { "type": "object" } }, "additionalProperties": false },
    "workspaceExport": { "type": "object", "required": ["workspaceId", "sourceRevision", "selection"], "properties": { "workspaceId": { "type": "string" }, "sourceRevision": { "type": "integer", "minimum": 0 }, "selection": { "type": "object" } }, "additionalProperties": false },
    "workspaceImport": { "type": "object", "required": ["manifestRef", "destinationTenantId", "policy"], "properties": { "manifestRef": { "type": "string" }, "destinationTenantId": { "type": "string" }, "policy": { "type": "object" } }, "additionalProperties": false },
    "workspaceTransfer": { "type": "object", "required": ["workspaceId", "sourceTenantId", "destinationTenantId", "policy"], "properties": { "workspaceId": { "type": "string" }, "sourceTenantId": { "type": "string" }, "destinationTenantId": { "type": "string" }, "policy": { "type": "object" } }, "additionalProperties": false }
  },
  "allOf": [
    { "$ref": "common.schema.json#/$defs/envelope" },
    { "oneOf": [
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "tenant.bootstrap" }, "payload": { "$ref": "#/$defs/tenantBootstrap" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "membership.update" }, "payload": { "$ref": "#/$defs/membershipUpdate" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "resource.create" }, "payload": { "$ref": "#/$defs/resourceCreate" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "resource.update" }, "payload": { "$ref": "#/$defs/resourceUpdate" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "resource.transition" }, "payload": { "$ref": "#/$defs/resourceTransition" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "resource.delete" }, "payload": { "$ref": "#/$defs/resourceDelete" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "grant.issue" }, "payload": { "$ref": "#/$defs/grantIssue" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "grant.delegate" }, "payload": { "$ref": "#/$defs/grantDelegate" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "grant.revoke" }, "payload": { "type": "object", "required": ["grantId"], "properties": { "grantId": { "type": "string" } }, "additionalProperties": false } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "binding.create" }, "payload": { "$ref": "#/$defs/bindingCreate" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "enum": ["binding.disable", "binding.remove"] }, "payload": { "type": "object", "required": ["bindingId"], "properties": { "bindingId": { "type": "string" } }, "additionalProperties": false } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "run.start" }, "payload": { "$ref": "#/$defs/runStart" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "turn.start" }, "payload": { "$ref": "#/$defs/turnStart" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "turn.claim" }, "payload": { "$ref": "#/$defs/turnClaim" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "turn.suspend" }, "payload": { "$ref": "#/$defs/turnSuspend" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "turn.retry" }, "payload": { "$ref": "#/$defs/turnRetry" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "turn.resume" }, "payload": { "$ref": "#/$defs/turnResume" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "turn.cancel" }, "payload": { "$ref": "#/$defs/turnCancel" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "turn.deliverEvent" }, "payload": { "$ref": "#/$defs/turnDeliverEvent" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "run.spawn" }, "payload": { "$ref": "#/$defs/runSpawn" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "run.branch.create" }, "payload": { "$ref": "#/$defs/runBranchCreate" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "run.branch.undo" }, "payload": { "$ref": "#/$defs/runBranchUndo" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "run.commit" }, "payload": { "$ref": "#/$defs/runCommit" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "environment.rotate" }, "payload": { "$ref": "#/$defs/environmentRotate" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "approval.resolve" }, "payload": { "$ref": "#/$defs/approvalResolve" } } },
      { "required": ["kind", "payload", "expectedLeaseEpoch"], "properties": { "kind": { "const": "invocation.prepare" }, "payload": { "$ref": "#/$defs/invocationPrepare" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "invocation.reconcile" }, "payload": { "$ref": "#/$defs/invocationReconcile" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "workspace.fork" }, "payload": { "$ref": "#/$defs/workspaceFork" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "workspace.export" }, "payload": { "$ref": "#/$defs/workspaceExport" } } },
      { "required": ["kind", "payload"], "properties": { "kind": { "const": "workspace.import" }, "payload": { "$ref": "#/$defs/workspaceImport" } } },
      { "required": ["kind", "payload", "expectedRevision"], "properties": { "kind": { "const": "workspace.transfer" }, "payload": { "$ref": "#/$defs/workspaceTransfer" } } }
    ] }
  ],
  "unevaluatedProperties": false
}
