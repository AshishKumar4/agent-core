{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/1/events.schema.json",
  "title": "Agent Core event",
  "type": "object",
  "required": ["protocolVersion", "streamId", "sequence", "eventId", "operationId", "kind", "timestamp", "payload"],
  "properties": {
    "protocolVersion": { "$ref": "common.schema.json#/$defs/version" },
    "streamId": { "$ref": "common.schema.json#/$defs/id" },
    "sequence": { "type": "integer", "minimum": 0 },
    "eventId": { "$ref": "common.schema.json#/$defs/id" },
    "operationId": { "$ref": "common.schema.json#/$defs/id" },
    "correlationId": { "$ref": "common.schema.json#/$defs/id" },
    "causationId": { "$ref": "common.schema.json#/$defs/id" },
    "resource": { "$ref": "common.schema.json#/$defs/resourceRef" },
    "revision": { "type": "integer", "minimum": 0 },
    "kind": { "type": "string", "minLength": 1 },
    "timestamp": { "$ref": "common.schema.json#/$defs/timestamp" },
    "payload": true,
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "additionalProperties": false
}
