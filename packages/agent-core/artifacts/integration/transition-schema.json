{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/coordinated-transition.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edition",
    "id",
    "state",
    "canonicalOwner",
    "symbols",
    "inputs",
    "remove",
    "replace",
    "invariants",
    "acceptance",
    "blockers",
    "completion"
  ],
  "properties": {
    "edition": { "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^TRANSITION-[A-Z0-9-]+$" },
    "state": {
      "enum": [
        "pending-inputs",
        "ready-for-coordinated-integration",
        "integration-candidate",
        "completed"
      ]
    },
    "canonicalOwner": { "type": "string", "pattern": "^W[0-9]+$" },
    "symbols": { "$ref": "#/$defs/strings" },
    "inputs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner", "commit", "state"],
        "properties": {
          "owner": { "type": "string", "pattern": "^W[0-9]+$" },
          "commit": { "type": ["string", "null"], "pattern": "^[a-f0-9]{40}$" },
          "state": {
            "enum": [
              "governance",
              "accepted-input",
              "pending-final-head",
              "integration-candidate",
              "completed"
            ]
          }
        }
      }
    },
    "remove": { "$ref": "#/$defs/strings" },
    "replace": { "$ref": "#/$defs/strings" },
    "invariants": { "$ref": "#/$defs/strings" },
    "acceptance": { "$ref": "#/$defs/strings" },
    "allowedForeignPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[^*?\\[\\]{}]+$"
      }
    },
    "changeManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "sha256", "paths"],
      "properties": {
        "base": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "owner", "sourceBlob", "candidateBlob", "disposition"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[^*?\\[\\]{}]+$"
              },
              "owner": { "type": "string", "pattern": "^W[0-9]+$" },
              "sourceBlob": {
                "anyOf": [{ "type": "string", "pattern": "^[a-f0-9]{40}$" }, { "const": "absent" }]
              },
              "candidateBlob": {
                "anyOf": [{ "type": "string", "pattern": "^[a-f0-9]{40}$" }, { "const": "deleted" }]
              },
              "disposition": { "enum": ["added", "modified", "deleted"] }
            }
          }
        }
      }
    },
    "closureManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "commit", "tree", "sha256", "paths"],
      "properties": {
        "base": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "tree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "owner", "sourceBlob", "candidateBlob", "disposition"],
            "properties": {
              "path": { "type": "string", "minLength": 1, "pattern": "^[^*?\\[\\]{}]+$" },
              "owner": { "type": "string", "pattern": "^W[0-9]+$" },
              "sourceBlob": {
                "anyOf": [{ "type": "string", "pattern": "^[a-f0-9]{40}$" }, { "const": "absent" }]
              },
              "candidateBlob": {
                "anyOf": [{ "type": "string", "pattern": "^[a-f0-9]{40}$" }, { "const": "deleted" }]
              },
              "disposition": { "enum": ["added", "modified", "deleted"] }
            }
          }
        }
      }
    },
    "remediationManifest": { "$ref": "#/properties/closureManifest" },
    "blockers": { "$ref": "#/$defs/strings" },
    "completion": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["commit", "tree", "artifacts", "tests"],
          "properties": {
            "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "tree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "artifacts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path", "blob", "sha256"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "blob": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                }
              }
            },
            "tests": { "$ref": "#/$defs/strings" },
            "checks": { "$ref": "#/$defs/strings" }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "state": { "const": "integration-candidate" } }
      },
      "then": { "required": ["changeManifest"] }
    },
    {
      "if": {
        "properties": {
          "id": { "const": "TRANSITION-W9-INTEGRATION-CANDIDATE" },
          "state": { "const": "completed" }
        }
      },
      "then": {
        "required": ["changeManifest", "closureManifest", "remediationManifest"]
      }
    }
  ],
  "$defs": {
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
