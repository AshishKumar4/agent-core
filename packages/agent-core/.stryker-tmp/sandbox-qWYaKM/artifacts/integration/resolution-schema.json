{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/spec-formal-resolutions.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["edition", "entries", "decisions"],
  "properties": {
    "edition": { "const": "1.0.0" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "prefixItems": [
              { "type": "string", "minLength": 1 },
              { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              { "const": "pending" },
              { "type": "null" }
            ]
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "sourceSha256",
              "archive",
              "archiveSha256",
              "state",
              "completion"
            ],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "sourceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "archive": { "type": "string", "minLength": 1 },
              "archiveSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "state": { "enum": ["applied", "rejected", "external-gated"] },
              "completion": { "$ref": "#/$defs/completion" },
              "outcome": { "$ref": "#/$defs/outcome" },
              "externalItems": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/externalItem" }
              }
            }
          }
        ]
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "obligationId",
          "source",
          "anchor",
          "disposition",
          "resolution",
          "integrationAction",
          "specAtoms"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^W[58]-[A-Z0-9-]+$" },
          "obligationId": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "anchor": { "type": "string", "pattern": "^#(?:/.*|[a-z0-9-]+)$" },
          "disposition": { "enum": ["accepted", "rejected"] },
          "resolution": { "type": "string", "minLength": 1 },
          "integrationAction": { "type": "string", "minLength": 1 },
          "specAtoms": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^(?:C13|P11)-[A-Z0-9-]+$" }
          }
        }
      }
    }
  },
  "$defs": {
    "outcome": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "treatment",
            "commit",
            "tree",
            "rationale",
            "tests",
            "checks",
            "artifacts",
            "items"
          ],
          "properties": {
            "kind": { "enum": ["applied", "rejected"] },
            "treatment": { "enum": ["accepted", "rejected", "superseded", "mixed"] },
            "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "tree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "rationale": { "type": "string", "minLength": 1 },
            "tests": { "$ref": "#/$defs/strings" },
            "checks": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "artifacts": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/artifact" }
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/outcomeItem" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "requestSha256",
            "approver",
            "keyFingerprint",
            "signature",
            "expiresAt"
          ],
          "properties": {
            "kind": { "const": "external-waiver" },
            "requestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "approver": { "type": "string", "minLength": 1 },
            "keyFingerprint": { "type": "string", "pattern": "^[A-F0-9]{40,64}$" },
            "signature": { "type": "string", "minLength": 1 },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "blob", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "blob": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "outcomeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "obligationId",
        "source",
        "anchor",
        "atomSha256",
        "treatment",
        "rationale",
        "artifactPaths",
        "tests",
        "checks"
      ],
      "properties": {
        "obligationId": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "anchor": { "type": "string", "pattern": "^#" },
        "atomSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "treatment": { "enum": ["accepted", "rejected", "superseded"] },
        "rationale": { "type": "string", "minLength": 1 },
        "artifactPaths": { "$ref": "#/$defs/strings" },
        "tests": { "$ref": "#/$defs/strings" },
        "checks": { "$ref": "#/$defs/strings" }
      }
    },
    "externalItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "obligationId",
        "source",
        "anchor",
        "atomSha256",
        "treatment",
        "consentRequestId"
      ],
      "properties": {
        "obligationId": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "anchor": { "type": "string", "pattern": "^#" },
        "atomSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "treatment": { "const": "external-gated" },
        "consentRequestId": { "const": "USER-CONSENT-W8-REMOTE-CONFORMANCE" }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "tree", "artifacts"],
      "properties": {
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "tree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact" }
        }
      }
    }
  }
}
