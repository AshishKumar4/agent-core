{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/request-archive.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["edition", "entries"],
  "properties": {
    "edition": { "const": "1.0.0" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner", "source", "sourceSha256", "path", "sha256"],
        "properties": {
          "owner": { "type": "string", "pattern": "^W[0-9]+$" },
          "source": { "type": "string", "minLength": 1 },
          "sourceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
