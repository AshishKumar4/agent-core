{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/imported-request-evidence.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["edition", "scope", "command", "minimumPercent", "metrics", "status"],
  "properties": {
    "edition": { "const": "1.0.0" },
    "scope": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "minLength": 1 },
    "minimumPercent": { "const": 95 },
    "status": { "const": "verified" },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statements", "branches", "functions", "lines"],
      "properties": {
        "statements": { "$ref": "#/$defs/metric" },
        "branches": { "$ref": "#/$defs/metric" },
        "functions": { "$ref": "#/$defs/metric" },
        "lines": { "$ref": "#/$defs/metric" }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "total", "percent"],
      "properties": {
        "covered": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 },
        "percent": { "type": "number", "minimum": 95, "maximum": 100 }
      }
    }
  }
}
