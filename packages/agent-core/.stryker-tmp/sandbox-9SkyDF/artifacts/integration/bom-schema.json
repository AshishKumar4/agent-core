{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-core.dev/schemas/signed-integration-bom.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["edition", "stage", "entries"],
  "properties": {
    "edition": { "const": "1.0.0" },
    "stage": { "enum": ["building", "final"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner", "commit", "tree", "commitSignature", "artifacts"],
        "properties": {
          "owner": { "type": "string", "pattern": "^W[0-9]+$" },
          "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
          "tree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
          "commitSignature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "keyFingerprint"],
            "properties": {
              "status": { "enum": ["unsigned", "verified"] },
              "keyFingerprint": { "type": ["string", "null"] }
            }
          },
          "artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "destination", "sourceSha256", "sha256", "normalization"],
              "allOf": [
                {
                  "if": {
                    "properties": { "normalization": { "const": "canonical-json-v1" } },
                    "required": ["normalization"]
                  },
                  "then": {
                    "properties": {
                      "source": { "pattern": "\\.json$" },
                      "destination": { "pattern": "\\.json$" }
                    }
                  }
                }
              ],
              "properties": {
                "source": { "type": "string", "minLength": 1 },
                "destination": { "type": "string", "minLength": 1 },
                "sourceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "normalization": { "enum": ["none", "canonical-json-v1"] }
              }
            }
          }
        }
      }
    }
  }
}
