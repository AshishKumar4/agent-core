{
  "name": "@agent-core/cloudflare",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @agent-core/core build && node ./scripts/build.mjs",
    "check:cloudflare-types": "wrangler types test/cloudflare/worker-configuration.d.ts --config wrangler.test.jsonc --check",
    "check:coverage": "pnpm --filter @agent-core/core quality --stage building --target coverage",
    "check:consumer": "pnpm build && node ./scripts/check-consumer.mjs",
    "check:exports": "pnpm check:consumer",
    "check:types": "pnpm --filter @agent-core/core build && tsc -p tsconfig.json && tsc -p test/tsconfig.json && tsc -p test/cloudflare/tsconfig.json",
    "lint": "pnpm --workspace-root exec oxlint --deny-warnings packages/agent-core-cloudflare/src packages/agent-core-cloudflare/test packages/agent-core-cloudflare/scripts",
    "test": "pnpm test:structural && pnpm test:cloudflare",
    "test:structural": "pnpm --filter @agent-core/core build && vitest run --config test/vitest.config.mjs",
    "test:cloudflare": "pnpm --filter @agent-core/core build && pnpm check:cloudflare-types && vitest run --config test/cloudflare/vitest.config.ts",
    "types:cloudflare": "wrangler types test/cloudflare/worker-configuration.d.ts --config wrangler.test.jsonc"
  },
  "dependencies": {
    "@agent-core/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "4.1.9",
    "wrangler": "4.110.0"
  }
}
