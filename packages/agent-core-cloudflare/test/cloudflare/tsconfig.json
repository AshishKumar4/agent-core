{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "ESNext.Disposable"],
    "types": ["@cloudflare/vitest-pool-workers/types", "vitest/globals"],
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["../../src/**/*.ts", "../queue-codecs.ts", "./**/*.ts"]
}
