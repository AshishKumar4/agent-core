{
  "name": "agent-core-monorepo",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "pnpm --recursive build",
    "check": "pnpm --filter @agent-core/core quality --stage building",
    "check:conformance": "pnpm --filter @agent-core/core quality --stage building --target conformance",
    "check:coverage": "pnpm --filter @agent-core/core quality --stage building --target coverage",
    "check:exports": "pnpm --filter @agent-core/core quality --stage building --target exports",
    "check:final": "pnpm --filter @agent-core/core quality --stage final",
    "check:implementation": "pnpm --filter @agent-core/core quality --stage building --target ledger",
    "check:traceability": "pnpm --filter @agent-core/core check:traceability",
    "check:types": "pnpm --recursive check:types",
    "format": "prettier --write .",
    "format:check": "node packages/agent-core/scripts/quality/format.mjs --base f558d0ff3f7e93308481ea09c3bf369abbdd19ba",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --recursive test"
  },
  "devDependencies": {
    "oxlint": "^1.30.0",
    "prettier": "^3.9.5"
  },
  "workspaces": [
    "packages/*"
  ]
}
